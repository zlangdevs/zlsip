?? lisp { ... } inside a function body emits statements/expressions.
fun main() >> i32 {
    i32 x = 0;
    lisp {
        (set x (+ 10 20))
    };
    @printf("x = %d\n", x);

    i32 i = 0;
    lisp {
        (while (< i 5)
            (@printf "i=%d\n" i)
            (set i (+ i 1)))
    };
    return 0;
}
