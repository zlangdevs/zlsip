.{
    .name = "zlisp",
    .version = "0.2.0",
    .format_version = 1,
    .api_min = 1,
    .api_max = 3,
    .targets = .{ "linux-x86_64" },
    .dependencies = .{},
    .modules = .{},
    .syntax_blocks = .{
        .{ .name = "lisp", .delimiter_mode = .brace_counting, .mandatory = true },
    },
    .cli_flags = .{},
    .native_libs = .{},
    .link_flags = .{},
    .expose = .{
        .global_syntax = true,
        .global_modules = false,
    },
    .entry = "zlisp.so",
}
